# Reapo-ai environment template
# Copy values into .env at repository root.

# ---- Embeddings ----
# hash | sentence-transformers | openai
AST_INDEXER_EMBEDDING_BACKEND=openai
# sentence-transformers/all-MiniLM-L6-v2, text-embedding-3-small, or text-embedding-3-large
AST_INDEXER_EMBEDDING_MODEL=text-embedding-3-large
AST_INDEXER_OPENAI_BASE_URL=
# text-embedding-3-large supports up to 3072 dimensions
AST_INDEXER_OPENAI_DIMENSIONS=3072
# Preferred source for OpenAI auth
OPENAI_API_KEY=
# Optional alias used by CLI defaults
AST_INDEXER_OPENAI_API_KEY=

# ---- Webhook runtime ----
AST_INDEXER_WEBHOOK_SECRET=replace-me
AST_INDEXER_HOST=127.0.0.1
AST_INDEXER_PORT=8090
AST_INDEXER_QUEUE_BACKEND=redis
AST_INDEXER_REDIS_URL=redis://localhost:6379/0
AST_INDEXER_REDIS_KEY=ast_indexer:index_jobs
AST_INDEXER_REDIS_DEAD_LETTER_KEY=ast_indexer:index_jobs:dead_letter
AST_INDEXER_MAX_ATTEMPTS=3

# ---- Observability ----
# jsonl | langfuse
AST_INDEXER_OBSERVABILITY_BACKEND=jsonl
AST_INDEXER_OBSERVABILITY_STRICT=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_MCP_IMAGE=langfuse/langfuse-mcp:latest
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# ---- Infra (compose) ----
POSTGRES_DB=langfuse
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=

# ---- GitHub App (Phase 2 migration) ----
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_WEBHOOK_SECRET=

# ---- OAuth token storage ----
# If both are set, server uses encrypted file token storage.
# AST_INDEXER_OAUTH_TOKEN_STORE_PATH can be absolute or relative to --state-root.
AST_INDEXER_OAUTH_TOKEN_STORE_PATH=oauth/tokens.enc
AST_INDEXER_OAUTH_ENCRYPTION_KEY=
