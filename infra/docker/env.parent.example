# Put this file one level above the repository root.
# Example parent folder layout:
# personal_brand/
#   .env
#   Reapo-ai/

# Required
POSTGRES_PASSWORD=change-me
LANGFUSE_NEXTAUTH_SECRET=change-me-min-32-chars
LANGFUSE_SALT=change-me-min-32-chars
AST_INDEXER_WEBHOOK_SECRET=change-me

# Optional overrides
POSTGRES_DB=langfuse
POSTGRES_USER=langfuse
POSTGRES_PORT=5432
REDIS_PORT=6379
LANGFUSE_PORT=3000
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
BACKEND_PORT=8090
FRONTEND_PORT=8080

# Langfuse API keys (for backend observability export)
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Backend runtime knobs
AST_INDEXER_OBSERVABILITY_BACKEND=langfuse
AST_INDEXER_OPENAI_BASE_URL=
AST_INDEXER_RESEARCH_MODEL=
AST_INDEXER_CONVERSATIONAL_MODEL=
OPENAI_API_KEY=

# Frontend build variables
VITE_API_BASE_URL=/api
VITE_LANGFUSE_SOCKET_URL=
